############################
# Unity 6.x
############################

# Core Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset Store, Cache, etc.
[Aa]sset[Ss]toreTools*/
[Uu]serSettings/

# Burst / IL2CPP / Codegen
[Bb]urstDebugInformation_DoNotShip*/
[Bb]urstCache/
[Bb]urst/
**/il2cpp_cache/
**/il2cpp_cache_backup/

# Cache folders (Unity 6 may generate more of these over time)
**/[Ss]criptAssemblies/
**/[Pp]ackageCache/

