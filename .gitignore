*.sln.iml

############################
# Logs / Reports / Profiles
############################

# Unity logs
*.log
*.trace
*.stacktrace

# Crash & profiler
sysinfo.txt
crash.dmp
*.memgraph
*.dgml

############################
# Builds & exported content
############################

# General build folders (if you use custom names, add them here)
[Bb]uild/
[Bb]uilds/
[Dd]eploy/
[Rr]elease/
[Rr]eleases/
[Pp]ublish/

# Platform-specific build artifacts
*.apk
*.aab
*.ipa
*.app
*.xcodeproj
*.xcworkspace
*.xcuserstate

############################
# TextMesh Pro / Generated assets
############################

# (Add more if you generate font atlases or other temp content)
[Tt]extMesh Pro/Resources/Font Assets/*_Backup*/

############################
# OS / Editor junk
############################

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*.swp
*.swo

############################
# Package managers / tooling
############################

# Node / npm / yarn (if you use them for tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python venv
.venv/
venv/

############################
# Keep these!
############################
# DO NOT IGNORE:
# - Assets/
# - ProjectSettings/
# - Packages/
# - .meta files

# They are critical for the project to work properly across machines.
# So we explicitly do NOT ignore any .meta files:
!*.meta